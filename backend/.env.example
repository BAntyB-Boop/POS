# จำเป็น: secret สำหรับเซ็น JWT — สุ่มด้วย: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# ที่เก็บไฟล์ SQLite (บน Railway ให้ mount volume ที่ /data แล้วตั้งเป็น /data/pos.db)
DB_FILE=./data/pos.db

# พอร์ตของ server (Railway จะ inject PORT ให้เอง ไม่ต้องตั้ง)
PORT=3000

# origin ของ frontend ที่อนุญาต คั่นด้วย comma (production ใส่ URL ของ Vercel)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
